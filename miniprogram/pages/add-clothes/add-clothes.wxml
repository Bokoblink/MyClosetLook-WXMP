<!--pages/add-clothes/add-clothes.wxml-->
<view class="container">
  <!-- 图片上传 -->
  <view class="form-item">
    <text class="label">图片 *</text>
    <view class="upload-box" bindtap="chooseImage">
      <image wx:if="{{image}}" src="{{image}}" class="preview"></image>
      <view wx:else class="upload-placeholder">+ 上传图片</view>
    </view>
  </view>

  <!-- 衣物名称 -->
  <view class="form-item">
    <text class="label">衣物名称 *</text>
    <input placeholder="请输入名称" value="{{name}}" bindinput="onInputName"/>
  </view>

  <!-- 分类 -->
  <view class="form-item">
    <text class="label">分类 *</text>
    <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
      <view class="picker">{{category || '请选择分类'}}</view>
    </picker>
  </view>

  <!-- 季节 -->
  <view class="form-item">
    <text class="label">季节</text>
    <picker mode="selector" range="{{seasons}}" bindchange="onSeasonChange">
      <view class="picker">{{season || '请选择季节'}}</view>
    </picker>
  </view>

  <!-- 上衣专属 -->
  <view wx:if="{{category == '上衣'}}">
    <view class="form-item">
      <text class="label">袖型</text>
      <picker mode="selector" range="{{sleeveTypes}}" bindchange="onSleeveChange">
        <view class="picker">{{sleeve || '请选择袖型'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">领型</text>
      <picker mode="selector" range="{{collarTypes}}" bindchange="onCollarChange">
        <view class="picker">{{collar || '请选择领型'}}</view>
      </picker>
    </view>
    
    <view class="form-item"><text class="label">衣长</text><input class="input" bindinput="onSizeInput" data-key="衣长" /></view>
    <view class="form-item"><text class="label">领围</text><input class="input" bindinput="onSizeInput" data-key="领围" /></view>
    <view class="form-item"><text class="label">胸围</text><input class="input" bindinput="onSizeInput" data-key="胸围" /></view>
    <view class="form-item"><text class="label">通袖</text><input class="input" bindinput="onSizeInput" data-key="通袖" /></view>
    <view class="form-item"><text class="label">袖口</text><input class="input" bindinput="onSizeInput" data-key="袖口" /></view>
    <view class="form-item"><text class="label">袖根</text><input class="input" bindinput="onSizeInput" data-key="袖根" /></view>

  </view>

  <!-- 下裙专属 -->
  <view wx:if="{{category == '下裙'}}">
    <view class="form-item">
      <text class="label">类型</text>
      <picker mode="selector" range="{{skirtTypes}}" bindchange="onTypeChange">
        <view class="picker">{{type || '请选择类型'}}</view>
      </picker>
    </view>
    <view class="form-item"><text class="label">长度</text><input class="input" bindinput="onSizeInput" data-key="长度" /></view>
  </view>

  <!-- 配饰专属 -->
  <view wx:if="{{category == '配饰'}}">
    <view class="form-item">
      <text class="label">类型</text>
      <picker mode="selector" range="{{accessoryTypes}}" bindchange="onTypeChange">
        <view class="picker">{{type || '请选择类型'}}</view>
      </picker>
    </view>
  </view>

  <!-- 备注 -->
  <view class="form-item">
    <text class="label">备注</text>
    <textarea placeholder="可选" value="{{remark}}" bindinput="onInputRemark"></textarea>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="saveClothe">保存</button>
</view>
