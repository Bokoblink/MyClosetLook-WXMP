/* pages/add-clothes/add-clothes.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 160rpx; /* 为保存按钮留出空间 */
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  font-size: 30rpx;
}

.label.required::after {
  content: '*';
  color: #fa5151;
  margin-left: 8rpx;
}

input, .picker, textarea {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 为单行输入框和选择器设置固定高度和垂直居中 */
input,
.picker {
  height: 88rpx;
  padding: 0 15rpx;
  display: flex;
  align-items: center;
}

/* 备注的多行文本框样式 */
textarea {
  height: 150rpx;
  padding: 15rpx;
}

.upload-box {
  width: 200rpx;
  height: 200rpx;
  border: 1px dashed #aaa;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 8rpx;
}

.upload-placeholder {
  color: #888;
}

.preview {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.save-btn {
  background: #07C160;
  color: white;
  border-radius: 8rpx;
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
}

.size-section {
  border: 1px solid #f0f0f0;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.sub-label {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 15rpx;
}

.size-section .form-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.size-section .label {
  width: 120rpx; /* 固定标签宽度 */
  font-weight: normal;
  margin-bottom: 0;
  flex-shrink: 0; /* 防止被压缩 */
}

.size-section .input {
  flex-grow: 1; /* 输入框占据剩余空间 */
}
