/* 分类导航样式 */
.category-tabs {
  display: flex;
  height: 80rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-tabs .tab {
  flex: 1;
  text-align: center;
  line-height: 80rpx;
  color: #666;
  position: relative;
}

.category-tabs .active {
  color: #07C160;
  font-weight: bold;
}

.category-tabs .active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: #07C160;
}

/* 筛选条件栏 */
.filter-bar {
  white-space: nowrap;
  padding: 20rpx;
  background: #f8f8f8;
  width: 100%;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 0 25rpx;
  margin-right: 20rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.filter-item.active {
  background: #07C160;
  color: white;
}