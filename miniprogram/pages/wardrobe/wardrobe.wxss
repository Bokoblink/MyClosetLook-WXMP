/* 筛选弹窗样式 */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s;
}

.filter-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.show .modal-content {
  transform: translateY(0);
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
}

.options-container {
  display: flex;
  flex-wrap: wrap;
  max-height: 60vh;
  overflow-y: auto;
}

.option-item {
  padding: 16rpx 30rpx;
  margin: 10rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.option-item.selected {
  background: #07C160;
  color: white;
}

.filter-buttons {
  display: flex;
  margin-top: 40rpx;
}

.filter-buttons button {
  flex: 1;
  margin: 0 20rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.reset-btn {
  background: #f5f5f5;
  color: #333;
}

.confirm-btn {
  background: #07C160;
  color: white;
}

/* 筛选标签激活样式 */
.filter-item.active {
  background: #07C160;
  color: white;
}