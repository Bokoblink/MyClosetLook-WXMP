<!-- 顶部分类导航 -->
<view class="category-tabs">
  <block wx:for="{{['上衣', '下裙', '配饰']}}" wx:key="*this">
    <view 
      class="tab {{activeCategory === item ? 'active' : ''}}"
      data-category="{{item}}"
      bindtap="changeCategory"
    >
      {{item}}
    </view>
  </block>
</view>

<!-- 筛选条件栏 -->
<scroll-view scroll-x class="filter-bar">
  <!-- 季节筛选 -->
  <view 
    class="filter-item {{selectedFilters.season.length ? 'active' : ''}}"
    data-type="season"
    bindtap="showFilter"
  >
    <text>季节</text>
    <text wx:if="{{selectedFilters.season.length}}">({{selectedFilters.season.length}})</text>
  </view>

  <!-- 动态筛选条件 -->
  <block wx:if="{{activeCategory === '上衣'}}">
    <view 
      class="filter-item {{selectedFilters.sleeveType.length ? 'active' : ''}}"
      data-type="sleeveType"
      bindtap="showFilter"
    >
      <text>袖型</text>
      <text wx:if="{{selectedFilters.sleeveType.length}}">({{selectedFilters.sleeveType.length}})</text>
    </view>
    <view 
      class="filter-item {{selectedFilters.collarType.length ? 'active' : ''}}"
      data-type="collarType"
      bindtap="showFilter"
    >
      <text>领型</text>
      <text wx:if="{{selectedFilters.collarType.length}}">({{selectedFilters.collarType.length}})</text>
    </view>
  </block>
  
  <!-- 下裙和配饰的筛选条件... -->
</scroll-view>