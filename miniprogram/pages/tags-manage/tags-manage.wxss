/* pages/tags-manage/tags-manage.wxss */

.container {
  padding: 20rpx;
  background-color: #f7f7f7;
  min-height: 100vh;
}

.group-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #07C160;
}

.tag-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

/* 1. 标题加粗 (参考add-outfit.wxss) */
.title {
  font-size: 32rpx;
  font-weight: bold;
}

/* 1. 添加按钮样式 (参考add-outfit.wxss) */
.add-btn {
  background-color: #07c160;
  color: white;
  /* 移除了button的默认边框和边距 */
  margin: 0;
  padding: 0 24rpx;
  line-height: 2.3;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-item, .field-item {
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  padding: 10rpx 15rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.field-item {
  flex-direction: column;
  align-items: flex-start;
  width: 100%;
  background-color: #f7f7f7;
  padding: 20rpx;
}

.field-info {
  display: flex;
  justify-content: space-between;
  width: 100%;
  align-items: center;
}

.field-key {
  font-weight: bold;
}

.field-placeholder {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
}

/* 3 & 4. 编辑和删除按钮新样式 */
.edit-btn,
.delete-btn {
  font-size: 36rpx;
  color: #bbb;
  padding: 0 10rpx;
}

.edit-btn:hover,
.delete-btn:hover {
  color: #333;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-dialog {
  background-color: #fff;
  width: 80%;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

/* 5. 弹窗副标题样式 */
.modal-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.modal-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 15rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
}

.modal-buttons button {
  flex: 1;
}